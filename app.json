        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.dotaneli.camerashare"
    },
    "extra": {
      "eas": {
        "projectId": "7eb802db-880d-4d33-bc5c-8391f630fab8"
      }
    },
    "owner": "dotaneli",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7eb802db-880d-4d33-bc5c-8391f630fab8"
    },
    "scheme": "camerashare",
    "plugins": [
      "expo-router"
    ]
  }
}
